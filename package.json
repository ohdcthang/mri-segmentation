{
  "name": "mri-segmentation",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "setup": "npm install && cd FE && npm install && cd ../BE && /usr/bin/python3 -m pip install --user -r requirements.txt",
    "dev:fe": "cd FE && npm run dev",
    "dev:be": "cd BE && /usr/bin/python3 -m uvicorn main:app --host 0.0.0.0 --port 8000",
    "dev": "concurrently \"npm run dev:be\" \"npm run dev:fe\" -c \"blue,green\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}